# ─────────────────────────────────────────────────────────────────────────────
# .env.example — YouTube Shorts Generator
# Copy this file to .env and fill in your real values for local development.
# NEVER commit .env to version control.
# In production, these are stored as GitHub Secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ── Pexels (stock footage) ────────────────────────────────────────────────────
# Get from: https://www.pexels.com/api/ → Free signup
PEXELS_API_KEY=your_pexels_api_key_here

# ── YouTube Data API v3 (OAuth 2.0) ──────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → OAuth 2.0 Client ID
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here

# YouTube refresh tokens — generated once per channel via oauth_setup.py
# Run: python oauth_setup.py --channel a
YOUTUBE_REFRESH_TOKEN_A=your_channel_a_refresh_token_here
# Run: python oauth_setup.py --channel b
YOUTUBE_REFRESH_TOKEN_B=your_channel_b_refresh_token_here

# ── GitHub (for dashboard manual trigger) ────────────────────────────────────
# Get from: GitHub → Settings → Developer settings → PAT (workflow scope)
GITHUB_PAT=your_github_pat_here

# ── GitHub repo (for workflow dispatch API calls) ─────────────────────────────
# Format: username/repo-name
GITHUB_REPO=your_username/Shorts-Generator
